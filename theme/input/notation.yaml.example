version: v1
symbols:
  - latex: "\\mathbb{E}[X]"
    meaning: expectation
    lean_candidates:
      - "∫ x, X x ∂μ"
  - latex: "\\mathrm{Var}(X)"
    meaning: variance
    lean_candidates:
      - "Var[X; μ]"
  - latex: "\\gamma"
    meaning: standard Gaussian measure on R
    lean_candidates:
      - "stdGaussian"
  - latex: "\\gamma^n"
    meaning: product Gaussian measure
    lean_candidates:
      - "stdGaussianPi n"
